                {
                  "key": "SpeedLimitValueOffset",
                  "widget": "option",
                  "visibility": [
                    {
                      "type": "all",
                      "conditions": [
                        {
                          "type": "param_compare",
                          "key": "SpeedLimitMode",
                          "op": ">",
                          "value": 0
                        },
                        {
                          "type": "param_compare",
                          "key": "SpeedLimitOffsetType",
                          "op": ">",
                          "value": 0
                        }
                      ]
                    }
                  ]
                }
              ]
            }
          ]
        },
        {

{
  "$schema": "./settings_ui.schema.json",
  "schema_version": "1.0",
  "panels": [
    {
      "id": "steering",
      "label": "Steering",
      "icon": "steering_wheel",
      "order": 1,
      "remote_configurable": true,
      "description": "Lateral control, lane changes, and steering behavior",
      "sections": [
        {
          "id": "mads",
          "title": "MADS",
          "description": "Modified Assistive Driving Safety",
          "items": [
            {
              "key": "Mads",
              "widget": "toggle",
              "enablement": [
                {
                  "type": "offroad_only"
                }
              ]
            }
          ],
          "sub_panels": [
            {
              "id": "mads_settings",
              "label": "MADS Settings",
              "trigger_key": "Mads",
              "trigger_condition": {
                "type": "param",
                "key": "Mads",
                "equals": true
              },
              "items": [
                {
                  "key": "MadsMainCruiseAllowed",
                  "widget": "toggle",
                  "enablement": [
                    {
                      "type": "offroad_only"
                    }
                  ]
                },
                {
                  "key": "MadsUnifiedEngagementMode",
                  "widget": "toggle",
                  "enablement": [
                    {
                      "type": "offroad_only"
                    }
                  ]
                },
                {
                  "key": "MadsSteeringMode",
                  "widget": "multiple_button",
                  "enablement": [
                    {
                      "type": "offroad_only"
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "id": "blinker",
          "title": "Blinker Control",
          "description": "Lateral pause behavior during turn signals",
          "items": [
            {
              "key": "BlinkerPauseLateralControl",
              "widget": "toggle",
              "sub_items": [
                {
                  "key": "BlinkerMinLateralControlSpeed",
                  "widget": "option",
                  "visibility": [
                    {
                      "type": "param",
                      "key": "BlinkerPauseLateralControl",
                      "equals": true
                    }
                  ]
                },
                {
                  "key": "BlinkerLateralReengageDelay",
                  "widget": "option",
                  "visibility": [
                    {
                      "type": "param",
                      "key": "BlinkerPauseLateralControl",
                      "equals": true
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "id": "torque",
          "title": "Torque Control",
          "description": "Steering torque tuning and lateral control method",
          "items": [
            {
              "key": "EnforceTorqueControl",
              "widget": "toggle",
              "visibility": [
                {
                  "type": "not",
                  "condition": {
                    "type": "capability",
                    "field": "steer_control_type",
                    "equals": "angle"
                  }
                }
              ],
              "enablement": [
                {
                  "type": "offroad_only"
                },
                {
                  "type": "capability",
                  "field": "torque_allowed",
                  "equals": true
                },
                {
                  "type": "param",
                  "key": "NeuralNetworkLateralControl",
                  "equals": false
                }
              ]
            },
            {
              "key": "NeuralNetworkLateralControl",
              "widget": "toggle",
              "visibility": [
                {
                  "type": "not",
                  "condition": {
                    "type": "capability",
                    "field": "steer_control_type",
                    "equals": "angle"
                  }
                }
              ],
              "enablement": [
                {
                  "type": "offroad_only"
                },
                {
                  "type": "capability",
                  "field": "torque_allowed",
                  "equals": true
                },
                {
                  "type": "param",
                  "key": "EnforceTorqueControl",
                  "equals": false
                }
              ]
            }
          ],
          "sub_panels": [
            {
              "id": "torque_settings",
              "label": "Torque Settings",
              "trigger_key": "EnforceTorqueControl",
              "trigger_condition": {
                "type": "param",
                "key": "EnforceTorqueControl",
                "equals": true
              },
              "items": [
                {
                  "key": "LiveTorqueParamsToggle",
                  "widget": "toggle",
                  "enablement": [
                    {
                      "type": "offroad_only"
                    }
                  ]
                },
                {
                  "key": "LiveTorqueParamsRelaxedToggle",
                  "widget": "toggle",
                  "visibility": [
                    {
                      "type": "param",
                      "key": "LiveTorqueParamsToggle",
                      "equals": true
                    }
                  ],
                  "enablement": [
                    {
                      "type": "offroad_only"
                    }
                  ]
                },
                {
                  "key": "CustomTorqueParams",
                  "widget": "toggle",
                  "enablement": [
                    {
                      "type": "offroad_only"
                    }
                  ]
                },
                {
                  "key": "TorqueParamsOverrideEnabled",
                  "widget": "toggle",
                  "visibility": [
                    {
                      "type": "param",
                      "key": "CustomTorqueParams",
                      "equals": true
                    }
                  ],
                  "enablement": [
                    {
                      "type": "offroad_only"
                    }
                  ]
                },
                {
                  "key": "TorqueParamsOverrideLatAccelFactor",
                  "widget": "option",
                  "visibility": [
                    {
                      "type": "param",
                      "key": "CustomTorqueParams",
                      "equals": true
                    }
                  ]
                },
                {
                  "key": "TorqueParamsOverrideFriction",
                  "widget": "option",
                  "visibility": [
                    {
                      "type": "param",
                      "key": "CustomTorqueParams",
                      "equals": true
                    }
                  ]
                },
                {
                  "key": "TorqueControlTune",
                  "widget": "multiple_button",
                  "enablement": [
                    {
                      "type": "offroad_only"
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "id": "lane_change",
          "title": "Lane Change",
          "description": "Automatic lane change timing and behavior",
          "items": [],
          "sub_panels": [
            {
              "id": "lane_change_settings",
              "label": "Lane Change Settings",
              "trigger_key": "AutoLaneChangeTimer",
              "items": [
                {
                  "key": "AutoLaneChangeTimer",
                  "widget": "multiple_button"
                },
                {
                  "key": "AutoLaneChangeBsmDelay",
                  "widget": "toggle",
                  "enablement": [
                    {
                      "type": "capability",
                      "field": "enable_bsm",
                      "equals": true
                    },
                    {
                      "type": "param_compare",
                      "key": "AutoLaneChangeTimer",
                      "op": ">",
                      "value": 0
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "cruise",
      "label": "Cruise",
      "icon": "cruise_control",
      "order": 2,

              "key": "SmartCruiseControlMap",
              "widget": "toggle",
              "visibility": [
                {
                  "type": "any",
                  "conditions": [
                    {
                      "type": "capability",
                      "field": "has_longitudinal_control",
                      "equals": true
                    },
                    {
                      "type": "capability",
                      "field": "has_icbm",
                      "equals": true
                    }
                  ]
                }
              ]

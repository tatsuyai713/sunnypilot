                    {
                      "type": "capability",
                      "field": "has_icbm",
                      "equals": true
                    }
                  ]
                }
              ],
              "sub_items": [
                {
                  "key": "CustomAccShortPressIncrement",
                  "widget": "option",
                  "visibility": [
                    {
                      "type": "param",
                      "key": "CustomAccIncrementsEnabled",
                      "equals": true
                    }
                  ]
                },
                {
                  "key": "CustomAccLongPressIncrement",
                  "widget": "option",
                  "visibility": [
                    {
                      "type": "param",
                      "key": "CustomAccIncrementsEnabled",
                      "equals": true
                    }
                  ]

                {
                  "key": "SpeedLimitOffsetType",
                  "widget": "multiple_button",
                  "visibility": [
                    {
                      "type": "param_compare",
                      "key": "SpeedLimitMode",
                      "op": ">",
                      "value": 0
                    }
